  {
    "id": "a-08-gerund-infinitive",
    "level": "advanced",
    "topic": { "en": "Gerund vs Infinitive", "hi": "Gerund vs Infinitive" },
    "explanation": {
      "en": "Gerund is verb+ing used like a noun. Infinitive is 'to' + verb.",
      "hi": "Gerund = verb+ing जो noun की तरह काम करे। Infinitive = to + verb।"
